### Test Interactive Message with URL Button
POST {{baseUrl}}/travelbot/webhook
Content-Type: application/json

{
  "object": "whatsapp_business_account",
  "entry": [{
    "id": "{{businessId}}",
    "changes": [{
      "value": {
        "messaging_product": "whatsapp",
        "metadata": {
          "display_phone_number": "PHONE_NUMBER",
          "phone_number_id": "PHONE_NUMBER_ID"
        },
        "messages": [{
          "from": "{{phoneNumber}}",
          "id": "wamid.test1",
          "timestamp": "1234567901",
          "interactive": {
            "type": "button",
            "button_reply": {
              "id": "support",
              "title": "Support"
            }
          },
          "type": "interactive"
        }]
      }
    }]
  }]
}

