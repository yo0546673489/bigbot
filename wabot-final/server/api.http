### Variables
@baseUrl = http://localhost:7878/api
# @baseUrl = https://bot.pro-digital.org/api
@phoneNumber = 84975868449
@businessId = 1078756750807219

### Registration Flow Tests
# Step 1: Start
POST {{baseUrl}}/travelbot/webhook
Content-Type: application/json

{
  "object": "whatsapp_business_account",
  "entry": [{
    "id": "{{businessId}}",
    "changes": [{
      "value": {
        "messaging_product": "whatsapp",
        "metadata": {
          "display_phone_number": "PHONE_NUMBER",
          "phone_number_id": "PHONE_NUMBER_ID"
        },
        "messages": [{
          "from": "{{phoneNumber}}",
          "id": "wamid.reg1",
          "timestamp": "1234567890",
          "text": {
            "body": "menu"
          },
          "type": "text"
        }]
      }
    }]
  }]
}

